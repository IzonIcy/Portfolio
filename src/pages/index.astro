---
import NotionLayout from '@/layouts/NotionLayout.astro';
import Mention from '@/components/Mention.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('writing');
const latestPosts = allPosts
  .sort(
    (a, b) =>
      new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime()
  )
  .slice(0, 5);
---

<NotionLayout>
  <div class="doc-title">Ryan Bahadori<span class="age">, 14</span></div>

  <div class="node" data-node>
    <div class="row">
      <span class="bullet-cell"><span class="bullet"></span></span>
      <span class="label">developer, wrestler, photographer</span>
    </div>
  </div>

  <div class="node has-children open" data-node>
    <div class="row has-children" tabindex="0">
      <span class="bullet-cell">
        <span class="bullet"></span>
        <span class="caret" aria-hidden>
          <svg viewBox="0 0 8 8" fill="none">
            <path d="M2 1l4 3-4 3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
      </span>
      <span class="label">now<span class="meta" data-now-stamp aria-hidden="true"></span></span>
    </div>
    <div class="children">
      <div class="node" data-node>
        <div class="row"><span class="bullet-cell"><span class="bullet"></span></span><span class="label">building useful things that scale</span></div>
      </div>
      <div class="node" data-node>
        <div class="row"><span class="bullet-cell"><span class="bullet"></span></span><span class="label">wrestling. always wrestling</span></div>
      </div>
      <div class="node" data-node>
        <div class="row"><span class="bullet-cell"><span class="bullet"></span></span><span class="label">high school junior out of california</span></div>
      </div>
    </div>
  </div>

  <div class="node has-children" data-node>
    <div class="row has-children" tabindex="0">
      <span class="bullet-cell">
        <span class="bullet"></span>
        <span class="caret" aria-hidden>
          <svg viewBox="0 0 8 8" fill="none">
            <path d="M2 1l4 3-4 3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
      </span>
      <span class="label">selected work<span class="count">6</span></span>
    </div>
    <div class="children">
      <div class="node" data-node>
        <div class="row"><span class="bullet-cell"><span class="bullet"></span></span><span class="label"><Mention href="https://github.com/IzonIcy/Spine">Spine</Mention><span class="meta">meta package manager for any *nix</span></span></div>
      </div>
      <div class="node" data-node>
        <div class="row"><span class="bullet-cell"><span class="bullet"></span></span><span class="label"><Mention href="https://github.com/IzonIcy/Clay">Clay</Mention><span class="meta">fast homebrew-compatible package manager in rust</span></span></div>
      </div>
      <div class="node" data-node>
        <div class="row"><span class="bullet-cell"><span class="bullet"></span></span><span class="label"><Mention href="https://github.com/IzonIcy/Angel">Angel</Mention><span class="meta">autonomous ai agent with persistent memory</span></span></div>
      </div>
      <div class="node" data-node>
        <div class="row"><span class="bullet-cell"><span class="bullet"></span></span><span class="label"><Mention href="https://github.com/IzonIcy/LumiCompiler">LumiCompiler</Mention><span class="meta">the official lumi compiler</span></span></div>
      </div>
      <div class="node" data-node>
        <div class="row"><span class="bullet-cell"><span class="bullet"></span></span><span class="label"><Mention href="https://github.com/IzonIcy/Mist">Mist</Mention><span class="meta">window tiling manager for mac</span></span></div>
      </div>
      <div class="node" data-node>
        <div class="row"><span class="bullet-cell"><span class="bullet"></span></span><span class="label"><Mention href="https://github.com/IzonIcy/DotFiles">DotFiles</Mention><span class="meta">personal dotfiles and dev environment</span></span></div>
      </div>
      <div class="node" data-node>
        <div class="row"><span class="bullet-cell"><span class="bullet"></span></span><span class="label"><a class="meta-link" href="/work">all work</a></span></div>
      </div>
    </div>
  </div>

  <div class="node has-children open" data-node>
    <div class="row has-children" tabindex="0">
      <span class="bullet-cell">
        <span class="bullet"></span>
        <span class="caret" aria-hidden>
          <svg viewBox="0 0 8 8" fill="none">
            <path d="M2 1l4 3-4 3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
      </span>
      <span class="label">writing<span class="count">{latestPosts.length}</span></span>
    </div>
    <div class="children">
      {latestPosts.map((post) => (
        <div class="node" data-node>
          <div class="row">
            <span class="bullet-cell"><span class="bullet"></span></span>
            <span class="label"><Mention href={`/writing/${post.slug}`}>{post.data.title.replace(/[.!?]+$/, '').toLowerCase()}</Mention><span class="meta">{post.data.publishedAt.slice(0, 4)}</span></span>
          </div>
        </div>
      ))}
      <div class="node" data-node>
        <div class="row"><span class="bullet-cell"><span class="bullet"></span></span><span class="label"><a class="meta-link" href="/writing">all essays</a></span></div>
      </div>
    </div>
  </div>

  <div class="node has-children open" data-node>
    <div class="row has-children" tabindex="0">
      <span class="bullet-cell">
        <span class="bullet"></span>
        <span class="caret" aria-hidden>
          <svg viewBox="0 0 8 8" fill="none">
            <path d="M2 1l4 3-4 3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
      </span>
      <span class="label">elsewhere</span>
    </div>
    <div class="children">
      <div class="node" data-node>
        <div class="row"><span class="bullet-cell"><span class="bullet"></span></span><span class="label"><Mention href="https://x.com/FlayIcy">x.com/FlayIcy</Mention></span></div>
      </div>
      <div class="node" data-node>
        <div class="row"><span class="bullet-cell"><span class="bullet"></span></span><span class="label"><Mention href="https://github.com/IzonIcy">github.com/IzonIcy</Mention></span></div>
      </div>
      <div class="node" data-node>
        <div class="row"><span class="bullet-cell"><span class="bullet"></span></span><span class="label"><button class="mention" type="button" data-mention data-email-copy aria-label="Copy email to clipboard">ryanbahadori74 <span aria-hidden="true">[at]</span><span class="sr-only">@</span> gmail <span aria-hidden="true">(dot)</span><span class="sr-only">.</span> com</button></span></div>
      </div>
    </div>
  </div>

  <div class="write-row" aria-hidden>
    <span class="ghost-bullet"></span>
    <span><span class="caret-blink"></span></span>
  </div>
</NotionLayout>

<style is:global>
  /* Outliner-specific styles, scoped via top-level class names used only on / */
  .doc-title {
    font-size: 24px;
    font-weight: 500;
    letter-spacing: -0.022em;
    line-height: 1.3;
    padding: 0 0 16px;
    color: var(--notion-ink);
    cursor: text;
    font-feature-settings: 'kern' 1, 'cv11', 'ss01';
    font-kerning: normal;
  }
  .doc-title .age {
    color: var(--notion-faint);
    font-weight: 400;
    line-height: 1.4;
  }
  .doc-title::after {
    content: '';
    display: inline-block;
    margin-left: 8px;
    opacity: 0;
    transform: translateX(-4px);
    transition: opacity 240ms ease, transform 240ms cubic-bezier(0.2, 0.7, 0.2, 1);
  }
  body.greeted .doc-title::after {
    content: '👋';
    opacity: 1;
    transform: translateX(0);
    animation: wave 1.2s ease-in-out;
  }
  @keyframes wave {
    0%, 100% { transform: rotate(0); }
    20%, 60% { transform: rotate(14deg); }
    40%, 80% { transform: rotate(-8deg); }
  }
  body.greeted .bullet {
    animation: pulse-bullet 800ms ease-out;
  }
  @keyframes pulse-bullet {
    0%   { transform: scale(1); }
    50%  { transform: scale(2.4); opacity: 0.4; }
    100% { transform: scale(1); }
  }
  .node > .row > .label {
    transition: color var(--dur-normal, 220ms) var(--ease-out-soft, ease), text-decoration-color var(--dur-normal, 220ms) var(--ease-out-soft, ease);
  }
  .node.done > .row > .label {
    text-decoration: line-through;
    text-decoration-color: var(--notion-faint);
    color: var(--notion-faint);
  }
  .node.done > .row > .bullet-cell > .bullet {
    background: var(--notion-faint);
    transform: scale(0.85);
    transition: background var(--dur-normal, 220ms) var(--ease-out-soft, ease), transform var(--dur-normal, 220ms) var(--ease-spring, ease);
  }

  .node {
    position: relative;
  }

  .row {
    position: relative;
    display: grid;
    grid-template-columns: 18px 1fr;
    column-gap: 12px;
    align-items: flex-start;
    padding: 2px 8px 2px 0;
    border-radius: 4px;
    cursor: text;
    font-size: 15px;
    line-height: 1.7;
    transition: background var(--dur-quick, 140ms) ease;
  }

  .row.has-children {
    cursor: pointer;
    transition:
      background var(--dur-quick, 140ms) ease,
      transform var(--dur-quick, 140ms) var(--ease-out-soft, ease);
  }
  .row.has-children:active {
    transform: scale(0.997);
  }
  .bullet-cell:active .bullet {
    transform: scale(0.7);
    transition: transform 100ms var(--ease-out-soft, ease);
  }
  .row:focus-visible {
    outline: none;
    background: var(--notion-row-focus);
  }
  .row:focus-visible::before {
    content: '';
    position: absolute;
    left: -14px;
    top: 4px;
    bottom: 4px;
    width: 2px;
    background: var(--notion-ink);
    border-radius: 1px;
  }

  .bullet-cell {
    position: relative;
    width: 18px;
    height: 24px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    cursor: pointer;
  }
  .bullet {
    display: block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--notion-ink);
    box-sizing: border-box;
    flex-shrink: 0;
    transition:
      opacity var(--dur-quick, 140ms) ease,
      transform 140ms var(--ease-out-soft, cubic-bezier(0.2, 0.7, 0.2, 1));
  }

  .node.has-children:not(.open) > .row > .bullet-cell > .bullet {
    background: transparent;
    border: 1.5px solid var(--notion-ink);
    width: 9px;
    height: 9px;
  }

  .caret {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    opacity: 0;
    color: var(--notion-faint);
    transition: opacity var(--dur-quick, 140ms) ease;
    pointer-events: none;
  }
  .caret svg {
    width: 8px;
    height: 8px;
    display: block;
    transition: transform var(--dur-normal, 220ms) var(--ease-out-soft, cubic-bezier(0.2, 0.7, 0.2, 1));
  }
  .node.open > .row > .bullet-cell > .caret svg { transform: rotate(90deg); }

  .label {
    min-width: 0;
    color: var(--notion-ink);
  }
  .label .meta {
    color: var(--notion-faint);
    font-weight: 400;
    padding-left: 8px;
    font-size: 12px;
    font-variant-numeric: tabular-nums;
  }
  .children {
    position: relative;
    margin-left: 26px;
    padding-left: 0;
    overflow: hidden;
    transition:
      max-height 260ms var(--ease-out-soft, cubic-bezier(0.2, 0.7, 0.2, 1)),
      opacity 200ms ease;
  }
  @media (hover: hover) and (pointer: fine) {
    .row:hover { background: var(--notion-row-hover); }
    .row:hover .bullet { transform: scale(1.4); }
    .node.has-children > .row:hover > .bullet-cell > .bullet { opacity: 0; }
    .node.has-children > .row:hover > .bullet-cell > .caret { opacity: 1; }
  }

  .node:not(.open) > .children {
    max-height: 0;
    opacity: 0;
    pointer-events: none;
  }
  .node.open > .children {
    max-height: 1200px;
    opacity: 1;
  }

  .write-row {
    position: relative;
    display: grid;
    grid-template-columns: 18px 1fr;
    column-gap: 12px;
    align-items: center;
    padding: 4px 8px 4px 0;
    border-radius: 4px;
    opacity: 0.65;
    transition: opacity var(--dur-normal, 200ms) ease, background var(--dur-quick, 140ms) ease;
  }
  .write-row:hover {
    background: var(--notion-row-hover);
    opacity: 1;
  }
  .ghost-bullet {
    width: 18px;
    height: 24px;
    display: grid;
    place-items: center;
  }
  .ghost-bullet::before {
    content: '';
    width: 7px;
    height: 7px;
    border-radius: 50%;
    border: 1px dashed var(--notion-dim);
    box-sizing: border-box;
  }
</style>

<script is:inline>
  (function init() {
    function wire() {
      /* fold / unfold for outliner parents */
      const parents = document.querySelectorAll('.node.has-children');
      parents.forEach(function (node) {
        if (node.dataset.wired) return;
        node.dataset.wired = '1';
        const row = node.querySelector(':scope > .row');
        if (!row) return;
        row.addEventListener('click', function (e) {
          if (e.target && e.target.closest && e.target.closest('a')) return;
          node.classList.toggle('open');
        });
        row.addEventListener('keydown', function (e) {
          if (e.key === 'Enter' || e.key === ' ') {
            e.preventDefault();
            node.classList.toggle('open');
          }
        });
      });

      /* now · {day · date} timestamp */
      const stamp = document.querySelector('[data-now-stamp]');
      if (stamp) {
        const now = new Date();
        const dayNames = ['sunday', 'monday', 'tuesday', 'wednesday', 'thursday', 'friday', 'saturday'];
        const day = dayNames[now.getDay()];
        const monthShort = now.toLocaleString('en-US', { month: 'short' }).toLowerCase();
        const monthLong = now.toLocaleString('en-US', { month: 'long' });
        stamp.textContent = day + ' · ' + now.getDate() + ' ' + monthShort;
        /* readable for screen readers */
        stamp.removeAttribute('aria-hidden');
        stamp.setAttribute('aria-label', `Today is ${day.charAt(0).toUpperCase() + day.slice(1)}, ${monthLong} ${now.getDate()}, ${now.getFullYear()}`);
      }

      /* double-click bullet → toggle done state (visual only) */
      document.querySelectorAll('.row .bullet-cell .bullet').forEach((b) => {
        if (b.dataset.wiredDone) return;
        b.dataset.wiredDone = '1';
        const cell = b.parentElement;
        if (!cell) return;
        cell.addEventListener('dblclick', (e) => {
          const node = e.target.closest('.node');
          if (!node) return;
          if (node.classList.contains('has-children')) return;
          node.classList.toggle('done');
        });
      });
    }

    wire();
    document.addEventListener('astro:after-swap', wire);

    /* easter egg: typing "ryan" triggers a wave + bullet pulse */
    (function easterEgg() {
      const TARGET = 'ryan';
      let buf = '';
      document.addEventListener('keydown', (e) => {
        const active = document.activeElement;
        if (active && /input|textarea/i.test(active.tagName)) return;
        if (e.key.length !== 1) return;
        buf = (buf + e.key.toLowerCase()).slice(-TARGET.length);
        if (buf === TARGET) {
          document.body.classList.add('greeted');
          setTimeout(() => document.body.classList.remove('greeted'), 2400);
        }
      });
    })();
  })();
</script>
