---
import NotionLayout from '@/layouts/NotionLayout.astro';
import Mention from '@/components/Mention.astro';
import { works } from '@/data/work';

const totalProjects = works.length;
---

<NotionLayout title="Work" description="stuff i built — solo projects, open source.">
  <a class="page-back" href="/"><span class="back-arrow" aria-hidden="true">↩</span>Index</a>
  <div class="doc-title">work<span class="age">, {totalProjects} projects</span></div>

  <p class="doc-sub">stuff i built — open source projects on github.</p>

  {works.map((work) => (
    <div class="node" data-node>
      <div class="row">
        <span class="bullet-cell"><span class="bullet"></span></span>
        <span class="label work-line">
          {work.link ? (
            <Mention href={work.link}>{work.title.toLowerCase()}</Mention>
          ) : (
            <span class="work-title">{work.title.toLowerCase()}</span>
          )}
          <span class="work-desc">{work.description.toLowerCase()}</span>
          {work.language && <span class="meta">{work.language}</span>}
        </span>
      </div>
    </div>
  ))}

  <div class="write-row" aria-hidden>
    <span class="ghost-bullet"></span>
    <span><span class="caret-blink"></span></span>
  </div>
</NotionLayout>

<style is:global>
  /* Outliner-specific styles, mirrored from the homepage. */
  .doc-title {
    font-size: 24px;
    font-weight: 500;
    letter-spacing: -0.022em;
    line-height: 1.3;
    padding: 0 0 16px;
    color: var(--notion-ink);
    cursor: text;
    font-feature-settings: 'kern' 1, 'cv11', 'ss01';
    font-kerning: normal;
  }
  .doc-title .age {
    color: var(--notion-faint);
    font-weight: 400;
    line-height: 1.4;
  }

  .doc-sub {
    font-size: 15px;
    line-height: 1.6;
    color: var(--notion-muted);
    margin: 0 0 24px;
    max-width: 540px;
  }

  .node {
    position: relative;
  }

  .row {
    position: relative;
    display: grid;
    grid-template-columns: 18px 1fr;
    column-gap: 12px;
    align-items: flex-start;
    padding: 2px 8px 2px 0;
    border-radius: 4px;
    cursor: text;
    font-size: 15px;
    line-height: 1.7;
    transition: background var(--dur-quick, 140ms) ease;
  }

  .row.has-children {
    cursor: pointer;
    transition:
      background var(--dur-quick, 140ms) ease,
      transform var(--dur-quick, 140ms) var(--ease-out-soft, ease);
  }
  .row.has-children:active { transform: scale(0.997); }

  .bullet-cell:active .bullet {
    transform: scale(0.7);
    transition: transform 100ms var(--ease-out-soft, ease);
  }
  .row:focus-visible {
    outline: none;
    background: var(--notion-row-focus);
  }
  .row:focus-visible::before {
    content: '';
    position: absolute;
    left: -14px;
    top: 4px;
    bottom: 4px;
    width: 2px;
    background: var(--notion-ink);
    border-radius: 1px;
  }

  .bullet-cell {
    position: relative;
    width: 18px;
    height: 24px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    cursor: pointer;
  }
  .bullet {
    display: block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--notion-ink);
    flex-shrink: 0;
    box-sizing: border-box;
    transition:
      opacity var(--dur-quick, 160ms) ease,
      transform 140ms var(--ease-out-soft, cubic-bezier(0.2, 0.7, 0.2, 1));
  }

  .node.has-children:not(.open) > .row > .bullet-cell > .bullet {
    background: transparent;
    border: 1.5px solid var(--notion-ink);
    width: 9px;
    height: 9px;
  }

  .caret {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    opacity: 0;
    color: var(--notion-faint);
    transition: opacity var(--dur-quick, 160ms) ease;
    pointer-events: none;
  }
  .caret svg {
    width: 8px;
    height: 8px;
    display: block;
    transition: transform var(--dur-normal, 220ms) var(--ease-out-soft, cubic-bezier(0.2, 0.7, 0.2, 1));
  }
  .node.open > .row > .bullet-cell > .caret svg { transform: rotate(90deg); }

  .label {
    min-width: 0;
    color: var(--notion-ink);
  }
  .label .meta {
    color: var(--notion-faint);
    font-weight: 400;
    padding-left: 10px;
    font-size: 12px;
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }
  .children {
    position: relative;
    margin-left: 26px;
    padding-left: 0;
    overflow: hidden;
    transition:
      max-height 260ms var(--ease-out-soft, cubic-bezier(0.2, 0.7, 0.2, 1)),
      opacity var(--dur-normal, 220ms) ease;
  }
  .node:not(.open) > .children {
    max-height: 0;
    opacity: 0;
    pointer-events: none;
  }
  .node.open > .children {
    max-height: 4000px;
    opacity: 1;
  }

  .work-line {
    display: inline-flex;
    align-items: baseline;
    gap: 10px;
    flex-wrap: wrap;
  }
  .work-line .work-desc {
    color: var(--notion-muted);
    font-size: 14.5px;
    white-space: nowrap;
  }
  .work-line .work-title {
    color: var(--notion-ink);
  }
  .work-line .meta,
  .work-line code,
  .work-line .badge {
    white-space: nowrap;
    vertical-align: baseline;
    padding-left: 0;
  }

  .write-row {
    position: relative;
    display: grid;
    grid-template-columns: 18px 1fr;
    column-gap: 12px;
    align-items: center;
    padding: 4px 8px 4px 0;
    border-radius: 4px;
    opacity: 0.65;
    transition: opacity var(--dur-normal, 200ms) ease, background var(--dur-quick, 140ms) ease;
  }
  .ghost-bullet {
    width: 18px;
    height: 24px;
    display: grid;
    place-items: center;
  }
  .ghost-bullet::before {
    content: '';
    width: 7px;
    height: 7px;
    border-radius: 50%;
    border: 1px dashed var(--notion-dim);
    box-sizing: border-box;
  }

  @media (hover: hover) and (pointer: fine) {
    .row:hover { background: var(--notion-row-hover); }
    .row:hover .bullet { transform: scale(1.4); }
    .node.has-children > .row:hover > .bullet-cell > .bullet { opacity: 0; }
    .node.has-children > .row:hover > .bullet-cell > .caret { opacity: 1; }
    .write-row:hover { background: var(--notion-row-hover); opacity: 1; }
  }
</style>

<script is:inline>
  (function init() {
    function wire() {
      const parents = document.querySelectorAll('.node.has-children');
      parents.forEach(function (node) {
        if (node.dataset.wired) return;
        node.dataset.wired = '1';
        const row = node.querySelector(':scope > .row');
        if (!row) return;
        row.addEventListener('click', function (e) {
          if (e.target && e.target.closest && e.target.closest('a')) return;
          node.classList.toggle('open');
        });
        row.addEventListener('keydown', function (e) {
          if (e.key === 'Enter' || e.key === ' ') {
            e.preventDefault();
            node.classList.toggle('open');
          }
        });
      });
    }

    wire();
    document.addEventListener('astro:after-swap', wire);
  })();
</script>
