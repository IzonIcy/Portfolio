---
import NotionLayout from '@/layouts/NotionLayout.astro';
import { getCollection, render } from 'astro:content';
import '@/styles/prose.css';

export async function getStaticPaths() {
  const posts = await getCollection('writing');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const cleanedTitle = post.data.title.replace(/[.!?]+$/, '').toLowerCase();

const dateFmt = new Date(post.data.publishedAt)
  .toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
  })
  .toLowerCase();

const raw = (post.body || '').replace(/[^\w\s]/g, '');
const words = raw.split(/\s+/).filter(Boolean).length;
const mins = Math.max(1, Math.round(words / 200));

const editUrl = `https://github.com/IzonIcy/Portfolio/edit/main/src/content/writing/${post.id}.mdx`;
---

<NotionLayout
  title={cleanedTitle}
  description={post.data.summary}
  image={post.data.image}
>
  <div class="reading-progress" aria-hidden="true"><span></span></div>

  <a class="page-back" href="/writing"><span class="back-arrow" aria-hidden="true">↩</span>Writing</a>

  <article class="post">
    <header class="post-head">
      <p class="post-date">
        <time datetime={post.data.publishedAt}>{dateFmt}</time>
        <span class="post-meta">· <time datetime={`PT${mins}M`}>{mins} min read</time></span>
      </p>
      <h1 class="post-title" tabindex="0">{cleanedTitle}</h1>
    </header>

    {post.data.image && (
      <img class="post-cover" alt={post.data.title} src={post.data.image} loading="lazy" decoding="async" />
    )}

    <div class="prose" data-prose>
      <Content />
    </div>

    <div class="post-write-row" aria-hidden="true">
      <span class="ghost-bullet"></span>
      <span class="post-caret-area">
        <span class="post-caret-blink"></span>
      </span>
    </div>

    <footer class="post-footer">
      <a href={editUrl} rel="noopener noreferrer" target="_blank">
        edit on github
      </a>
    </footer>

    <div class="toast" id="post-toast" role="status" aria-live="polite" hidden></div>
  </article>

  <aside class="post-toc" aria-label="On this page" id="post-toc"></aside>
</NotionLayout>

<script is:inline>
  (function () {
    var toastTimer;
    function showToast(text) {
      var toast = document.getElementById('post-toast');
      if (!toast) return;
      toast.textContent = text;
      toast.hidden = false;
      requestAnimationFrame(function () { toast.classList.add('show'); });
      clearTimeout(toastTimer);
      toastTimer = setTimeout(function () {
        toast.classList.remove('show');
        setTimeout(function () { toast.hidden = true; }, 240);
      }, 1500);
    }

    function wire() {
      /* Make headings focusable so the keyboard accent-bar can show */
      var proseHeadings = document.querySelectorAll('.prose h1, .prose h2, .prose h3');
      proseHeadings.forEach(function (h) {
        if (!h.hasAttribute('tabindex')) h.setAttribute('tabindex', '0');
      });

      /* Copy section URL on anchor click — Notion's link-to-block */
      var anchors = document.querySelectorAll('.prose .anchor');
      anchors.forEach(function (a) {
        if (a.dataset.wired) return;
        a.dataset.wired = '1';
        a.setAttribute('aria-label', 'Copy link to section');
        a.addEventListener('click', function (e) {
          e.preventDefault();
          var heading = a.closest('h1, h2, h3, h4, h5, h6');
          if (!heading || !heading.id) return;
          var url = window.location.origin + window.location.pathname + '#' + heading.id;
          try {
            history.replaceState(null, '', '#' + heading.id);
          } catch (_) {}
          if (navigator.clipboard && navigator.clipboard.writeText) {
            navigator.clipboard.writeText(url).then(function () {
              a.classList.add('copied');
              setTimeout(function () { a.classList.remove('copied'); }, 1200);
              showToast('Copied link to section');
            }).catch(function () {});
          }
        });
      });

      /* Build right-side TOC if there are >= 3 H2 headings */
      buildToc();
    }

    function buildToc() {
      var prose = document.querySelector('.prose');
      var toc = document.getElementById('post-toc');
      if (!prose || !toc) return;
      /* Clear any prior content (after-swap) */
      toc.innerHTML = '';
      toc.hidden = false;
      var heads = prose.querySelectorAll('h2, h3');
      var h2count = prose.querySelectorAll('h2').length;
      if (h2count < 3) { toc.hidden = true; return; }
      var ul = document.createElement('ul');
      heads.forEach(function (h, i) {
        if (!h.id) h.id = 'h-' + i;
        var li = document.createElement('li');
        li.className = 'post-toc-' + h.tagName.toLowerCase();
        var a = document.createElement('a');
        a.href = '#' + h.id;
        a.textContent = h.textContent;
        li.appendChild(a);
        ul.appendChild(li);
      });
      toc.appendChild(ul);
      /* highlight current — scroll-driven via IntersectionObserver,
         keyboard-driven via focus events on the headings themselves */
      var links = toc.querySelectorAll('a');
      function setCurrent(id) {
        links.forEach(function (l) {
          l.classList.toggle('current', l.getAttribute('href') === '#' + id);
        });
      }
      if ('IntersectionObserver' in window) {
        var io = new IntersectionObserver(function (entries) {
          entries.forEach(function (e) {
            if (e.isIntersecting) setCurrent(e.target.id);
          });
        }, { rootMargin: '-40% 0px -55% 0px' });
        heads.forEach(function (h) { io.observe(h); });
      }
      /* Tabbing into a heading should also update the TOC, even if the
         heading is already inside the IntersectionObserver's sweet spot. */
      heads.forEach(function (h) {
        h.addEventListener('focus', function () { setCurrent(h.id); });
      });
    }

    wire();
    document.addEventListener('astro:after-swap', wire);
  })();

  (function progress() {
    function init() {
      var bar = document.querySelector('.reading-progress span');
      if (!bar) return;
      function update() {
        var h = document.documentElement;
        var scroll = h.scrollTop;
        var max = h.scrollHeight - h.clientHeight;
        var pct = max > 0 ? (scroll / max) * 100 : 0;
        bar.style.width = pct + '%';
      }
      window.addEventListener('scroll', update, { passive: true });
      update();
    }
    init();
    document.addEventListener('astro:after-swap', init);
  })();
</script>
